[32m+[m[32m## Project Overview[m
[32m+[m
[32m+[m[32mSQLRustGo is a Rust implementation of a relational database system supporting SQL-92 subset. Built from scratch with a modern layered architecture.[m
[32m+[m
[32m+[m[32m## Common Commands[m
[32m+[m
[32m+[m[32m```bash[m
[32m+[m[32m# Build[m
[32m+[m[32mcargo build --all-features[m
[32m+[m
[32m+[m[32m# Run tests[m
[32m+[m[32mcargo test --all-features[m
[32m+[m
[32m+[m[32m# Run a single test[m
[32m+[m[32mcargo test test_name --all-features[m
[32m+[m
[32m+[m[32m# Lint with clippy[m
[32m+[m[32mcargo clippy --all-features -- -D warnings[m
[32m+[m
[32m+[m[32m# Format check[m
[32m+[m[32mcargo fmt --check --all[m
[32m+[m
[32m+[m[32m# Doc tests[m
[32m+[m[32mcargo test --doc[m
[32m+[m
[32m+[m[32m# Run REPL[m
[32m+[m[32mcargo run --bin sqlrustgo[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m## Architecture[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32m┌─────────────────────────────────────┐[m
[32m+[m[32m│           main.rs (REPL)             │[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│           executor/                 │  ← Query execution[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│           parser/                    │  ← SQL → AST[m
[32m+[m[32m│           lexer/                    │  ← SQL → Tokens[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│           storage/                   │  ← Page, BufferPool, B+ Tree[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│         transaction/                 │  ← WAL, TxManager[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│           network/                   │  ← TCP server/client[m
[32m+[m[32m├─────────────────────────────────────┤[m
[32m+[m[32m│           types/                     │  ← Value, SqlError[m
[32m+[m[32m└─────────────────────────────────────┘[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m## Key Modules[m
[32m+[m
[32m+[m[32m| Module | Purpose |[m
[32m+[m[32m|--------|---------|[m
[32m+[m[32m| `lexer` | Tokenizes SQL input |[m
[32m+[m[32m| `parser` | Parses tokens into Statement AST |[m
[32m+[m[32m| `storage` | Page management, BufferPool (LRU), B+ Tree indexing |[m
[32m+[m[32m| `executor` | Executes SQL statements |[m
[32m+[m[32m| `transaction` | Write-Ahead Log, BEGIN/COMMIT/ROLLBACK |[m
[32m+[m[32m| `network` | TCP server/client with MySQL-style protocol |[m
[32m+[m
[32m+[m[32m## Rust Edition[m
[32m+[m
[32m+[m[32mUses Rust edition 2024 with Tokio async runtime.[m
